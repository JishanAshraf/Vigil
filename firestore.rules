
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile data.
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Alerts can be read by any authenticated user.
    // Alerts can be created by any authenticated user.
    // Alerts can be updated (for comments, reporters) by any authenticated user.
    // Alerts can only be deleted by the user who created them.
    match /alerts/{alertId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth.uid == resource.data.user.id;
    }
  }
}
